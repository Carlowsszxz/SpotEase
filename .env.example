# ===== SpotEase AI Chat Proxy =====
# Copy this file to .env and adjust values.

# Server
CHAT_PROXY_PORT=8787
CHAT_CORS_ORIGIN=http://localhost:5173

# Provider mode: auto | huggingface | ollama
AI_PROVIDER=auto

# Hugging Face free-tier
HF_API_KEY=
HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# Local Ollama fallback
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Safety and usage limits
CHAT_MAX_INPUT_CHARS=6000
CHAT_MAX_MESSAGES=12
CHAT_MAX_TOKENS=400
CHAT_RATE_LIMIT_REQUESTS=25
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_REQUEST_TIMEOUT_MS=30000
